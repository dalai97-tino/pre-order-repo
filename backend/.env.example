# Local development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/preorder_shop

# Production Supabase shared pooler
# Replace <SUPABASE_DB_PASSWORD> with the database password from Supabase.
# If the password has special characters, URL-encode it before pasting.
# DATABASE_URL=postgresql+psycopg://postgres.uppkmxkczoqxddtozcix:<SUPABASE_DB_PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
APP_NAME=Pre-order Ecommerce API
APP_ENV=development
JWT_SECRET_KEY=change-this-secret-before-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
